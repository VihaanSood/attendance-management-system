// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────
// Database schema for the Attendance Management System
// Uses PostgreSQL via Prisma ORM
// ─────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── User (Organization owner / tenant) ──────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String // bcrypt hashed
  organization String // Organization/company name
  role         UserRole @default(ADMIN)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations — all data is scoped to this user (multi-tenant)
  employees Employee[]
  holidays  Holiday[]
  settings  OrgSettings?

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
}

// ── Organization Settings ────────────────────────────────────────
model OrgSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  workingDays Int      @default(26) // Days used for salary calc
  weeklyOff   Json     @default("[0,6]") // 0=Sun, 6=Sat (JSON array)
  currency    String   @default("USD")
  timezone    String   @default("UTC")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("org_settings")
}

// ── Employee ─────────────────────────────────────────────────────
model Employee {
  id          String   @id @default(cuid())
  userId      String // Foreign key → User (tenant isolation)
  name        String
  age         Int
  salary      Decimal  @db.Decimal(12, 2) // Monthly salary
  role        String // Job title / position
  department  String?
  joiningDate DateTime
  email       String?
  phone       String?
  address     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  attendance    Attendance[]
  leaveRequests LeaveRequest[]

  // Composite index for fast tenant-scoped queries
  @@index([userId, isActive])
  @@index([userId, name])
  @@map("employees")
}

// ── Attendance Record ─────────────────────────────────────────────
model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  userId     String // Denormalized for fast tenant queries
  date       DateTime         @db.Date
  status     AttendanceStatus
  note       String? // Optional note (e.g., reason for leave)
  checkIn    DateTime? // Optional check-in time
  checkOut   DateTime? // Optional check-out time
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  // Prevent duplicate attendance for same employee on same day
  @@unique([employeeId, date])
  @@index([userId, date])
  @@index([employeeId, date])
  @@map("attendance")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  HALF_DAY
  HOLIDAY
}

// ── Leave Request ────────────────────────────────────────────────
model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  userId     String
  startDate  DateTime    @db.Date
  endDate    DateTime    @db.Date
  type       LeaveType
  reason     String
  status     LeaveStatus @default(PENDING)
  reviewedAt DateTime?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, status])
  @@index([userId, status])
  @@map("leave_requests")
}

enum LeaveType {
  SICK
  CASUAL
  ANNUAL
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

// ── Holiday Calendar ─────────────────────────────────────────────
model Holiday {
  id          String   @id @default(cuid())
  userId      String
  name        String
  date        DateTime @db.Date
  description String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("holidays")
}
